{
  "openapi": "3.0.1",
  "info": {
    "title": "Engineering Design PPT Agent",
    "version": "1.0.0",
    "description": "Chat with the Engineering Design PPT agent via APIM"
  },
  "servers": [
    {
      "url": "https://ai-gateway-apim-poc-my.azure-api.net/foundry-privatevnet-app"
    }
  ],
  "paths": {
    "/chat": {
      "post": {
        "operationId": "chatWithAgent",
        "summary": "Ask a question about engineering design presentations",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["prompt"],
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "Your question about engineering design presentations"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "string",
                      "description": "The agent answer"
                    },
                    "use_case": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
