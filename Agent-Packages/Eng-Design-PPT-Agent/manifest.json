{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/vDevPreview/MicrosoftTeams.schema.json",
  "manifestVersion": "devPreview",
  "version": "1.0.0",
  "id": "2f3f3c91-1f4f-4c0f-b40c-1b6f6f1b1222",
  "name": {
    "short": "Eng Design PPT Agent",
    "full": "Engineering Design PPT Agent via APIM"
  },
  "developer": {
    "name": "Michael Yaacoub at Microsoft",
    "websiteUrl": "https://ai-gateway-apim-poc-my.azure-api.net",
    "privacyUrl": "https://ai-gateway-apim-poc-my.azure-api.net/privacy",
    "termsOfUseUrl": "https://ai-gateway-apim-poc-my.azure-api.net/terms"
  },
  "description": {
    "short": "Foundry agent package for engineering design presentations.",
    "full": "Teams package for the Engineering Design PPT agent routed through Azure API Management."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#0F6CBD",
  "composeExtensions": [
    {
      "composeExtensionType": "apiBased",
      "apiSpecificationFile": "apiSpecificationFile.json",
      "commands": [
        {
          "id": "chatWithAgent",
          "type": "query",
          "title": "Ask Eng Design PPT",
          "description": "Ask a question about engineering design presentations",
          "initialRun": false,
          "apiResponseRenderingTemplateFile": "responseRenderingTemplate.json",
          "parameters": [
            {
              "name": "prompt",
              "title": "Question",
              "description": "Your question about engineering design presentations",
              "inputType": "text"
            }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["ai-gateway-apim-poc-my.azure-api.net"]
}
