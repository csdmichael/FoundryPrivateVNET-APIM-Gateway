{
  "version": "devPreview",
  "jsonPath": "$",
  "responseLayout": "list",
  "responseCardTemplate": {
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.5",
    "body": [
      {
        "type": "TextBlock",
        "text": "${response}",
        "wrap": true
      }
    ]
  },
  "previewCardTemplate": {
    "title": "Eng Design PPT Agent",
    "text": "${response}"
  }
}
